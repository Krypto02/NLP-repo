    {
      "doc_file": "doc_ml_basics.pdf",
      "title": "Introduction to Machine Learning",
      "summary": "A primer covering supervised/unsupervised learning, bias-variance tradeoff, and evaluation metrics."
    },
    {
      "doc_file": "doc_climate.pdf",
      "title": "Climate Change: Causes and Effects",
      "summary": "A short report on greenhouse gas emissions, global temperature trends, and mitigation strategies."
    },
    {
      "doc_file": "doc_python.docx",
      "title": "Python Programming Best Practices",
      "summary": "A guide covering PEP-8, virtual environments, testing, and type hints."
    },
    {
      "doc_file": "doc_databases.pdf",
      "title": "Databases and SQL Fundamentals",
      "summary": "Covers relational databases, SQL queries, ACID properties, normalization, indexing, and NoSQL."
    },
    {
      "doc_file": "doc_cybersecurity.pdf",
      "title": "Cybersecurity Fundamentals",
      "summary": "Covers the CIA triad, encryption, common attack vectors, firewalls, MFA, and zero-trust architecture."
    },
    {
      "doc_file": "doc_deep_learning.pdf",
      "title": "Deep Learning and Neural Networks",
      "summary": "Covers neural network architectures, backpropagation, CNNs, RNNs, transformers, and regularization."
    },
    {
      "doc_file": "doc_web_dev.pdf",
      "title": "Web Development Basics",
      "summary": "Covers HTML, CSS, JavaScript, backend frameworks, HTTP, and web security best practices."
    }
